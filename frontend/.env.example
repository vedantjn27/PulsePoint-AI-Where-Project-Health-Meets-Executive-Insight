# Local development:
# Keep this value when running the frontend against your local FastAPI backend.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Deployed frontend:
# In your hosting platform, set VITE_API_BASE_URL to your deployed backend URL.
# Example:
# VITE_API_BASE_URL=https://your-deployed-backend.example.com
